APP_ENV=development
PORT=18437
HOST=0.0.0.0
BACKEND_PORT=18437
FRONTEND_PORT=8080
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_gateway?sslmode=disable
DB_AUTO_MIGRATE=false
REDIS_URL=redis://redis:6379/0
TLS_ENABLED=false
TLS_CERT_FILE=/certs/backend/server.crt
TLS_KEY_FILE=/certs/backend/server.key
FRONTEND_TLS_ENABLED=false
FRONTEND_TLS_CERT_FILE=/certs/frontend/server.crt
FRONTEND_TLS_KEY_FILE=/certs/frontend/server.key
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:8080
CORS_ALLOW_ORIGINS=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:18437
DEFAULT_BALANCE_STRATEGY=priority
REQUEST_TIMEOUT_SECONDS=120
MODEL_SYNC_INTERVAL_SECONDS=900
OPENAI_BASE_URL=https://api.openai.com
NEXT_PUBLIC_API_BASE_URL=/api/proxy
DEFAULT_BACKEND_INTERNAL_URL=http://api:18437
PROXY_TIMEOUT_MS=125000
NEXT_PUBLIC_DEFAULT_BACKEND_ID=local-docker
NEXT_PUBLIC_DEFAULT_BACKEND_NAME=Local Docker Backend
NEXT_PUBLIC_DEFAULT_BACKEND_URL=http://api:18437
NEXT_PUBLIC_DEFAULT_BACKEND_INSECURE_TLS=false
